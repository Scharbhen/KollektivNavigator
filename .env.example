# Public base URL used by the extractor to download uploaded files.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Explicit mode switch. Keep false for the real extractor pipeline.
DEMO_MODE="false"

# RabbitMQ connection and queue contract.
RABBITMQ_URL="amqp://extractor_user:RmqPass_2026_xYz@localhost:5672"
RABBITMQ_TARGET_QUEUE="doc-2-md"
RABBITMQ_REPLY_QUEUE="demo-responses"
RABBITMQ_METADATA_QUEUE="doc-2-metadata"
RABBITMQ_REPLY_QUEUE_DURABLE="true"
RABBITMQ_CONNECT_RETRIES="5"
RABBITMQ_CONNECT_RETRY_DELAY_MS="2000"

# Timeout for RabbitMQ publish confirms in milliseconds.
RABBITMQ_PUBLISH_TIMEOUT_MS="10000"
RABBITMQ_CHAT_TIMEOUT_MS="120000"

# Prompt contract for document Q&A via doc-2-metadata.
QA_ANSWER_KEY="answer"
QA_SYSTEM_PROMPT="Ты помощник по анализу документов. Отвечай только на основе содержимого документа. Если данных недостаточно, укажи это явно. Верни только JSON объект вида {\"request_id\": \"...\", \"answer\": \"...\"}. request_id бери из запроса и не изменяй."
QA_PROMPT_TEMPLATE="request_id=\"{request_id}\". Вопрос пользователя: \"{question}\". Верни JSON с request_id и answer."
